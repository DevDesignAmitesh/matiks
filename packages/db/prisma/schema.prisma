generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum friendRequestStatus {
  PENDING
  ACCEPTED
  IGNORED
}

enum questionOperations {
  ADD
  SUB
  MUL
  DIV
}

enum gameStatus {
  WAITING_FOR_PLAYERS
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum gameMode {
  ONLINE_SEARCH
  PLAY_WITH_FRIEND
}

enum gameType {
  BLITZ
}

enum userStatus {
  IDOL
  PLAYING
  SEARCHING
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  userName   String
  isVerified Boolean    @default(false)
  isOnline   Boolean    @default(false)
  rating     Int        @default(1000)
  lastSeen   DateTime   @default(now())
  status     userStatus @default(IDOL)

  sender   FriendsMapUser[] @relation("user_sender")
  receiver FriendsMapUser[] @relation("user_receiver")

  playedGames GamePlayer[]
  gameResult  GameResult[]
  gameAnswers UserAnswer[]

  game        Game[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rating])
  @@index([isOnline])
}

model UserAnswer {
  id         String   @id @default(uuid())
  gameId     String
  userId     String
  questionId String
  answer     Int
  isCorrect  Boolean
  timeSpent  Int
  answeredAt DateTime @default(now())

  game     Game     @relation(fields: [gameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId, questionId])
}

model FriendsMapUser {
  id String @id @default(uuid())

  status      friendRequestStatus @default(PENDING)
  requestedAt DateTime
  respondedAt DateTime?

  senderId String
  sender   User   @relation("user_sender", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("user_receiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receiverId, senderId])
  @@index([receiverId, senderId])
  @@index([senderId, status])
  @@index([receiverId, status])
}

model Question {
  id        String             @id @default(uuid())
  operation questionOperations
  operand1  Int
  operand2  Int
  answer    Int
  createdAt DateTime           @default(now())

  gameQuestions GameQuestion[]
  answers       UserAnswer[]
}

model GameQuestion {
  id         String @id @default(uuid())
  gameId     String
  questionId String
  orderIndex Int

  game     Game     @relation(fields: [gameId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([gameId, questionId])
}

model Game {
  id                 String         @id @default(uuid())
  status             gameStatus     @default(WAITING_FOR_PLAYERS)
  // TODO: it should have foreingkey with User tabel
  createdBy          String
  creator            User     @relation(fields: [createdBy], references: [id])  
  
  mode               gameMode
  type               gameType
  endTime            DateTime?
  startTime          DateTime?
  rematchRequestedBy String?
  questions          GameQuestion[]

  timeLimit       Int
  numberOfPlayers Int

  players GamePlayer[]
  results GameResult[]
  answers UserAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdBy])
  @@index([mode, type])
}

model GamePlayer {
  id     String @id @default(uuid())
  gameId String
  userId String
  game   Game   @relation(fields: [gameId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
}

model GameResult {
  id     String @id @default(uuid())
  gameId String
  userId String
  game   Game   @relation(fields: [gameId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  score            Int
  correctAnswers   Int
  incorrectAnswers Int
  timeSpent        Int
  rank             Int
  ratingBefore     Int
  ratingAfter      Int
  ratingChange     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
}

model Otp {
  id String @id @default(uuid())

  value      String
  identifier String @unique

  createdAt DateTime @default(now())
  expiresAt DateTime
}
